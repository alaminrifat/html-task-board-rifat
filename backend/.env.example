# Database
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=postgres
DATABASE_NAME=taskboard

# JWT
AUTH_JWT_SECRET=your-secure-secret-key-min-32-chars-here
AUTH_TOKEN_COOKIE_NAME=accessToken
AUTH_DASHBOARD_TOKEN_COOKIE_NAME=dashboardAccessToken
AUTH_TOKEN_EXPIRE_TIME=24h
AUTH_TOKEN_EXPIRED_TIME_REMEMBER_ME=30d
AUTH_REFRESH_TOKEN_COOKIE_NAME=refreshToken
AUTH_REFRESH_TOKEN_EXPIRE_TIME=7d

# App
PORT=3000
MODE=DEV
FRONTEND_URL=http://localhost:5173
DASHBOARD_URL=http://localhost:5174
ALLOW_ORIGINS=http://localhost:5173,http://localhost:5174

# Mail (SMTP)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_FROM=TaskBoard <your-email@gmail.com>

# AWS S3
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_S3_BUCKET=taskboard-attachments
AWS_REGION=ap-northeast-2

# Firebase
FIREBASE_API_KEY=your-firebase-api-key

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Admin Seed
ADMIN_EMAIL=admin@taskboard.app
ADMIN_PASSWORD=Admin@123456
